# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave service-role -- nunca expor no cliente, apenas em rotas server-side
SUPABASE_SERVICE_ROLE_KEY=

# Email transacional (Gmail via Nodemailer)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# URL pública da aplicação (usada para gerar links em emails, ex: visualização de documentos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# M-Pesa (agregador de pagamentos) -- integração antiga, a remover na Fase 4
MPESA_API_KEY=
MPESA_BASE_URL=
MPESA_TIMEOUT=30000

# PaySuite (gateway de pagamentos -- Fase 4, ver docs/auditoria-inicial.md)
# Token de API: Dashboard PaySuite > Settings > API Access
PAYSUITE_API_TOKEN=
# Segredo usado para validar a assinatura HMAC dos webhooks (X-Webhook-Signature)
PAYSUITE_WEBHOOK_SECRET=

# Origem permitida para CORS/CSRF (deve ser um único domínio de produção, nunca "*")
ALLOWED_ORIGIN=http://localhost:3000
